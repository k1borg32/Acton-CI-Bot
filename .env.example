# ─── Required ───
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789

# ─── Acton Runner ───
# Default points at the GHCR-hosted image. Docker auto-pulls if the local
# tag is missing — survives Coolify's periodic image-prune. Override with a
# locally-built tag if you want pinned/offline behaviour:
#   docker build -t acton-runner:latest -f docker/Dockerfile.acton .
#   ACTON_DOCKER_IMAGE=acton-runner:latest
ACTON_DOCKER_IMAGE=ghcr.io/k1borg32/acton-ci-bot/acton-runner:latest
CONTAINER_MEMORY=512m
CONTAINER_CPUS=1
CONTAINER_PIDS_LIMIT=256
CLONE_TIMEOUT=60
BUILD_TIMEOUT=180
MAX_REPO_SIZE_KB=51200

# ─── Rate Limits ───
MAX_CHECKS_PER_HOUR=5
MAX_CHECKS_PER_DAY=30
MAX_CONCURRENT_PER_USER=1
MAX_CONCURRENT_GLOBAL=3
# Capacity guard for the VPS — when this is hit the bot returns
# "at capacity" for the next 24h window. Size to your hosting.
MAX_CHECKS_GLOBAL_PER_DAY=1000

# ─── Database ───
DB_PATH=data/acton_bot.db

# ─── Donations (optional) ───
# If set, the bot shows a /donate command + main-menu button pointing at
# this TON wallet. Leave empty to hide the donation surface entirely.
DONATE_TON_ADDRESS=
# DONATE_NOTE=Custom note shown above the address. Defaults to a generic one.

# ─── GitHub Webhooks (Phase 2) ───
# Shared secret used to verify X-Hub-Signature-256 on incoming GitHub
# webhooks. Generate with:  openssl rand -hex 32
# Set the same value in your GitHub repo's webhook settings.
# Leave empty to disable webhooks (the /webhooks/github endpoint will 500).
GITHUB_WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=3000

# (Optional) Personal Access Token (or fine-grained PAT with
# `pull-requests: write` on the target repos). When set, every webhook
# report is also posted as a PR comment on GitHub. Leave empty to skip.
# Generate at: https://github.com/settings/tokens
GITHUB_BOT_TOKEN=

# ─── Linux deployment only ───
# Host's docker group GID — botuser inside the container needs to be in this
# group to talk to /var/run/docker.sock. Find yours with:
#   getent group docker
# Debian/Ubuntu default is 999. Leave unset on Windows/macOS dev.
# DOCKER_GID=999
